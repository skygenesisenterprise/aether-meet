generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  OWNER
}

enum AuthProvider {
  CREDENTIALS
  GITHUB
  GOOGLE
  MICROSOFT
}

enum VerificationPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  OAUTH_STATE
  MAGIC_LINK
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum PresenceStatus {
  ONLINE
  BUSY
  AWAY
  OFFLINE
}

enum ThemeMode {
  LIGHT
  DARK
  SYSTEM
}

enum ChannelType {
  TEAM
  DIRECT
  GROUP
  ANNOUNCEMENT
}

enum ChannelVisibility {
  PUBLIC
  PRIVATE
  DIRECT
}

enum MessageType {
  TEXT
  SYSTEM
  FILE
  CALL
}

enum MeetingStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELED
}

enum MeetingParticipantStatus {
  INVITED
  ACCEPTED
  DECLINED
  JOINED
  LEFT
}

enum NotificationType {
  MESSAGE
  MENTION
  TEAM
  MEETING
  FILE
  SECURITY
  SYSTEM
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum FileKind {
  DOCUMENT
  PRESENTATION
  SPREADSHEET
  ARCHIVE
  IMAGE
  VIDEO
  AUDIO
  OTHER
}

model User {
  id                String              @id @default(uuid())
  email             String              @unique
  username          String?             @unique
  name              String
  passwordHash      String?
  role              UserRole            @default(USER)
  avatarUrl         String?
  active            Boolean             @default(true)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  profile           UserProfile?
  settings          UserSettings?
  authAccounts      AuthAccount[]
  sessions          AuthSession[]
  devices           Device[]
  securityEvents    SecurityActivity[]
  workspaceMembers  WorkspaceMember[]
  invitedMembers    WorkspaceMember[]   @relation("WorkspaceMemberInviter")
  ownedWorkspaces   Workspace[]         @relation("WorkspaceOwner")
  createdTeams      Team[]              @relation("TeamCreator")
  teamMembers       TeamMember[]
  createdChannels   Channel[]           @relation("ChannelCreator")
  channelMembers    ChannelMember[]
  sentMessages      Message[]           @relation("MessageAuthor")
  createdMeetings   Meeting[]           @relation("MeetingOrganizer")
  meetingAttendees  MeetingParticipant[]
  notifications     Notification[]
  calendars         Calendar[]
  calendarEvents    CalendarEvent[]     @relation("CalendarEventAuthor")
  ownedFiles        FileAsset[]         @relation("FileOwner")
}

model UserProfile {
  id            String         @id @default(uuid())
  userId        String         @unique
  firstName     String?
  lastName      String?
  displayName   String?
  title         String?
  bio           String?
  phone         String?
  locale        String         @default("fr")
  timeZone      String         @default("Europe/Paris")
  statusMessage String?
  presence      PresenceStatus @default(ONLINE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id                   String    @id @default(uuid())
  userId               String    @unique
  theme                ThemeMode @default(SYSTEM)
  language             String    @default("fr")
  emailNotifications   Boolean   @default(true)
  mentionNotifications Boolean   @default(true)
  meetingReminders     Boolean   @default(true)
  soundEnabled         Boolean   @default(true)
  cameraLabel          String?
  microphoneLabel      String?
  secureSession        Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthAccount {
  id                String       @id @default(uuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  email             String?
  accessToken       String?
  refreshToken      String?
  scopes            String[]
  tokenExpiresAt    DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId, provider])
}

model AuthSession {
  id               String    @id @default(uuid())
  userId           String
  deviceId         String?
  tokenHash        String    @unique
  refreshTokenHash String?   @unique
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  lastActiveAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  device           Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)
}

model VerificationToken {
  id         String              @id @default(uuid())
  identifier String
  tokenHash  String              @unique
  purpose    VerificationPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime            @default(now())

  @@index([identifier, purpose])
}

model Device {
  id          String             @id @default(uuid())
  userId      String
  name        String
  type        String
  os          String?
  browser     String?
  ipAddress   String?
  isTrusted   Boolean            @default(false)
  lastSeenAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    AuthSession[]
}

model SecurityActivity {
  id          String    @id @default(uuid())
  userId      String
  type        String
  title       String
  description String?
  ipAddress   String?
  userAgent   String?
  occurredAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
}

model Workspace {
  id            String            @id @default(uuid())
  slug          String            @unique
  name          String
  description   String?
  logoUrl       String?
  ownerId       String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  owner         User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members       WorkspaceMember[]
  teams         Team[]
  channels      Channel[]
  meetings      Meeting[]
  notifications Notification[]
  calendars     Calendar[]
  files         FileAsset[]
}

model WorkspaceMember {
  id          String           @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole    @default(MEMBER)
  status      MembershipStatus @default(ACTIVE)
  invitedById String?
  invitedAt   DateTime?
  joinedAt    DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy   User?            @relation("WorkspaceMemberInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([workspaceId, userId])
  @@index([userId, status])
}

model Team {
  id          String       @id @default(uuid())
  workspaceId String
  name        String
  slug        String
  description String?
  color       String?
  isPrivate   Boolean      @default(false)
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User         @relation("TeamCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members     TeamMember[]
  channels    Channel[]
  files       FileAsset[]

  @@unique([workspaceId, slug])
}

model TeamMember {
  id        String           @id @default(uuid())
  teamId     String
  userId     String
  role       WorkspaceRole   @default(MEMBER)
  status     MembershipStatus @default(ACTIVE)
  joinedAt   DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  team       Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId, status])
}

model Channel {
  id           String            @id @default(uuid())
  workspaceId  String
  teamId       String?
  createdById  String
  type         ChannelType       @default(TEAM)
  visibility   ChannelVisibility @default(PUBLIC)
  name         String
  slug         String?
  topic        String?
  archivedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team         Team?             @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdBy    User              @relation("ChannelCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members      ChannelMember[]
  messages     Message[]
  meetings     Meeting[]
  files        FileAsset[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, type, visibility])
}

model ChannelMember {
  id          String    @id @default(uuid())
  channelId    String
  userId       String
  lastReadAt   DateTime?
  muted        Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  channel      Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model Message {
  id         String      @id @default(uuid())
  channelId   String
  authorId    String?
  type        MessageType @default(TEXT)
  content     String
  metadata    Json?
  editedAt    DateTime?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  channel     Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author      User?       @relation("MessageAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([channelId, createdAt])
}

model Meeting {
  id           String                     @id @default(uuid())
  workspaceId  String
  channelId    String?
  organizerId  String
  title        String
  description  String?
  location     String?
  startsAt     DateTime
  endsAt       DateTime
  status       MeetingStatus              @default(SCHEDULED)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  workspace    Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel      Channel?                   @relation(fields: [channelId], references: [id], onDelete: SetNull)
  organizer    User                       @relation("MeetingOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  participants MeetingParticipant[]
  calendarEvents CalendarEvent[]

  @@index([workspaceId, startsAt])
}

model MeetingParticipant {
  id         String                   @id @default(uuid())
  meetingId   String
  userId      String?
  displayName String?
  email       String?
  status      MeetingParticipantStatus @default(INVITED)
  joinedAt    DateTime?
  leftAt      DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  meeting     Meeting                  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user        User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([meetingId, status])
  @@index([userId, status])
}

model Notification {
  id          String               @id @default(uuid())
  userId      String
  workspaceId String?
  type        NotificationType
  priority    NotificationPriority @default(MEDIUM)
  title       String
  body        String
  link        String?
  readAt      DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, readAt, createdAt])
}

model Calendar {
  id          String          @id @default(uuid())
  workspaceId String?
  ownerId     String
  name        String
  color       String?
  isPrimary   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  workspace   Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  owner       User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  events      CalendarEvent[]

  @@unique([ownerId, name])
}

model CalendarEvent {
  id          String      @id @default(uuid())
  calendarId  String
  meetingId   String?
  authorId    String?
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime
  allDay      Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  calendar    Calendar    @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  meeting     Meeting?    @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  author      User?       @relation("CalendarEventAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([calendarId, startsAt])
}

model FileAsset {
  id            String    @id @default(uuid())
  workspaceId    String
  teamId         String?
  channelId      String?
  ownerId        String
  name           String
  kind           FileKind
  mimeType       String?
  sizeBytes      BigInt    @default(0)
  storageKey     String?
  locationLabel  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team           Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  channel        Channel?  @relation(fields: [channelId], references: [id], onDelete: SetNull)
  owner          User      @relation("FileOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([workspaceId, kind, updatedAt])
}
