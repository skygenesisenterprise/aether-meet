{
  "expo": {
    "name": "Aether Meet",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./public/aethermeet-icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.aetherbank.mobile",
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.aetherbank.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "mobile"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Autorisez Aether Meet a utiliser Face ID pour deverrouiller l'application et confirmer votre identite."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Autorisez Aether Meet a utiliser la camera pour rejoindre une reunion ou scanner une invitation."
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
