{
  "name": "@aether-meet/apps",
  "version": "1.0.0",
  "description": "Frontend application for Aether Meet App & Mobile Experience",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "mobile:start:clear": "pnpm exec expo start -c",
    "mobile:android": "pnpm exec expo start --android",
    "mobile:ios": "pnpm exec expo start --ios",
    "mobile:web": "pnpm exec expo start --web",
    "mobile:prebuild": "pnpm exec expo prebuild",
    "mobile:prebuild:clean": "pnpm exec expo prebuild --clean",
    "mobile:run:android": "pnpm exec expo run:android",
    "mobile:run:ios": "pnpm exec expo run:ios",
    "mobile:open:android": "studio android",
    "mobile:open:ios": "open ios/Aether\\ Bank.xcworkspace",
    "mobile:doctor": "pnpm exec expo-doctor",
    "mobile:install": "pnpm exec expo install",
    "mobile:fix": "pnpm exec expo install --fix",
    "mobile:lint": "pnpm exec expo lint",
    "dev:web": "DOCS_DEV=false pnpm next dev -p 3000 -H 0.0.0.0",
    "build": "next build",
    "build:web": "node ./scripts/build-web.mjs",
    "web:start": "next start",
    "web:lint": "eslint",
    "test": "node --test --experimental-strip-types tests/platform-api/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next out .expo",
    "lint": "expo lint"
  },
