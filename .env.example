# Cloud / Dokploy
DOMAIN_HOST=
APP_IMAGE_TAG=cloud
DATABASE_URL=
PRISMA_SCHEMA_DEPLOY=true
PRISMA_SCHEMA_DEPLOY_STRATEGY=push
ALLOW_MIGRATION_FAILURE=false

# Database
PG_USER=postgres
PG_PASS=postgres
PG_DB=postgres

# Auth
JWT_SECRET=replace-me
JWT_ISSUER=aether-meet

# Logging
LOG_LEVEL=info
HTTP_ACCESS_LOGS=false
API_ACCESS_LOGS=false
WORKER_WAIT_FOR_DB=false

# Redis
REDIS_ENABLED=true
REDIS_REQUIRED=true
REDIS_PASSWORD=
REDIS_URL=redis://default:${REDIS_PASSWORD}@redis:6379/0
REDIS_KEY_PREFIX=aether-meet:v1
REDIS_DEFAULT_TTL=300
REDIS_CONNECT_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_MAX_RETRIES=3

# WebRTC / LiveKit
WEBRTC_PROVIDER=livekit
LIVEKIT_ENABLED=true
LIVEKIT_INTERNAL_URL=http://livekit:7880
LIVEKIT_PUBLIC_URL=wss://webrtc.meet.skygenesisenterprise.com
WEBRTC_PUBLIC_URL=wss://webrtc.meet.skygenesisenterprise.com
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
WEBRTC_NODE_ID=aether-meet-node-1
WEBRTC_REGION=eu-west
WEBRTC_TOKEN_TTL=10m
WEBRTC_ROOM_EMPTY_TIMEOUT=5m
WEBRTC_PARTICIPANT_TTL=2m
WEBRTC_HEALTHCHECK_INTERVAL=30s
WEBRTC_NODE_CAPACITY=500
WEBRTC_DRAINING=false
LIVEKIT_PORT=7880
LIVEKIT_RTC_TCP_PORT=7881
LIVEKIT_RTP_PORT_MIN=50000
LIVEKIT_RTP_PORT_MAX=50100
LIVEKIT_IMAGE_TAG=v1.8.3
TURN_ENABLED=false
TURN_URL=
TURN_USERNAME=
TURN_PASSWORD=
